# ================================
# Python Virtual Environment
# ================================
venv/
.venv/
env/
ENV/

# ================================
# Python Cache & Compiled Files
# ================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ================================
# Distribution / Build
# ================================
dist/
build/
*.egg-info/
*.egg
.eggs/

# ================================
# Environment Variables (NEVER push secrets)
# ================================
.env
.env.local
.env.*.local

# ================================
# RAG Storage (auto-generated at runtime)
# FAISS index + chunked text are large binary files
# ================================
storage/
*.index
*.pkl
*.faiss

# ================================
# Uploaded PDFs (user data, not source code)
# ================================
uploads/
*.pdf

# ================================
# OS Generated Files
# ================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ================================
# IDE & Editor Files
# ================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ================================
# Logs
# ================================
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# ================================
# Jupyter Notebooks (if you experiment)
# ================================
.ipynb_checkpoints/
*.ipynb

# ================================
# Testing & Coverage
# ================================
.pytest_cache/
.coverage
htmlcov/